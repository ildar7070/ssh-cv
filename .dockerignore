# Keep the build context minimal: only source, go.mod/sum, and the
# example content are needed to build the image.
.git
.github
.claude
bin
dist

# Docs and meta — not needed at build time.
*.md
CLAUDE.md

# SSH host keys and local env must never enter the image.
.ssh
.host_key
.host_key.pub
.env
.env.local

# Operator-supplied content; the image bakes in content.example.toml.
content.toml

# Editor / OS cruft.
.vscode
.idea
.DS_Store

# Go test/build leftovers.
*.test
*.out
vendor
